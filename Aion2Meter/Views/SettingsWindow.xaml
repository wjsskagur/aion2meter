<Window x:Class="Aion2Meter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" Width="300" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 제목 -->
            <TextBlock Grid.Row="0" Text="⚙ 설정"
                       FontSize="14" FontWeight="Bold"
                       FontFamily="{StaticResource GameFont}"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,14"/>

            <!-- ── 화면 ───────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Text="화면"
                           FontSize="10" FontWeight="Bold"
                           FontFamily="{StaticResource GameFont}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- 항상 최상위 -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="항상 최상위"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <CheckBox HorizontalAlignment="Right"
                              IsChecked="{Binding Settings.AlwaysOnTop}"/>
                </Grid>

                <!-- 컴팩트 모드 -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="컴팩트 모드"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <CheckBox HorizontalAlignment="Right"
                              IsChecked="{Binding Settings.CompactMode}"/>
                </Grid>

                <!-- 투명도 -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="투명도"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="{StaticResource GameFont}"
                               Text="{Binding Settings.Opacity, StringFormat={}{0:P0}}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
                <Slider Minimum="0.1" Maximum="1.0"
                        Value="{Binding Settings.Opacity}"
                        TickFrequency="0.1"
                        Foreground="{StaticResource AccentBrush}"
                        Margin="0,0,0,8"/>

                <!-- 창 너비 -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="창 너비"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="{StaticResource GameFont}"
                               Text="{Binding Settings.WindowWidth, StringFormat={}{0:F0}px}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
                <Slider Minimum="240" Maximum="600"
                        Value="{Binding Settings.WindowWidth}"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>

            <!-- ── 딜 표시 ─────────────────────────────── -->
            <StackPanel Grid.Row="2" Margin="0,0,0,14">
                <TextBlock Text="딜 표시"
                           FontSize="10" FontWeight="Bold"
                           FontFamily="{StaticResource GameFont}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- 파티원만 표시 -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="파티원만 표시"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <CheckBox HorizontalAlignment="Right"
                              IsChecked="{Binding Settings.FilterByKnownPlayers}"/>
                </Grid>
                <TextBlock Text="해제 시 보스를 공격한 모든 플레이어 표시"
                           FontSize="10" Margin="0,0,0,8"
                           FontFamily="{StaticResource GameFont}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- 내 캐릭터 상단 고정 -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="내 캐릭터 상단 고정"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <CheckBox HorizontalAlignment="Right"
                              IsChecked="{Binding Settings.PinLocalPlayer}"/>
                </Grid>

                <!-- 자동 전투 종료 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="자동 종료 대기 (초)"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Settings.AutoEndSeconds}"
                             Background="#0F1F3D" Foreground="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="4,2" FontFamily="Consolas"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- 정렬 기준 -->
                <Grid>
                    <TextBlock Text="정렬 기준"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White" VerticalAlignment="Center"/>
                    <ComboBox HorizontalAlignment="Right" Width="100"
                              SelectedValue="{Binding Settings.SortBy}"
                              SelectedValuePath="Tag"
                              Background="#0F1F3D" Foreground="White"
                              BorderBrush="{StaticResource BorderBrush}">
                        <ComboBoxItem Content="총 피해량" Tag="TotalDamage"/>
                        <ComboBoxItem Content="DPS" Tag="Dps"/>
                        <ComboBoxItem Content="타격 횟수" Tag="HitCount"/>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <!-- ── 전투 결과 자동 발송 ────────────────── -->
            <StackPanel Grid.Row="3" Margin="0,0,0,14">
                <TextBlock Text="전투 결과 발송"
                           FontSize="10" FontWeight="Bold"
                           FontFamily="{StaticResource GameFont}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding Settings.AutoUpload}"
                                  IsEnabled="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="{StaticResource GameFont}"
                                   FontSize="11">
                            <Run Text="자동 발송" Foreground="#666677"/>
                            <Run Text=" (준비 중)" Foreground="#444455" FontSize="10"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ── Npcap 상태 ──────────────────────────── -->
            <Border Grid.Row="4" Margin="0,0,0,14"
                    Background="#0D1B3E" CornerRadius="4" Padding="8,6">
                <Grid>
                    <TextBlock Text="Npcap 상태"
                               FontSize="11"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="White"/>
                    <TextBlock x:Name="NpcapStatus"
                               HorizontalAlignment="Right"
                               FontSize="11" FontWeight="Bold"
                               FontFamily="{StaticResource GameFont}"/>
                </Grid>
            </Border>

            <!-- ── 버튼 ───────────────────────────────── -->
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="취소" Width="70" Height="28"
                        Margin="0,0,8,0"
                        Style="{StaticResource IconButton}"
                        Foreground="White"
                        Click="CancelButton_Click"/>
                <Button Content="저장" Width="70" Height="28"
                        Cursor="Hand"
                        Click="SaveButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
