<Window x:Class="Aion2Meter.Views.BossDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="전투 상세"
        Width="520" Height="560"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="0,0,0,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="BossTitleText"
                               FontSize="14" FontWeight="Bold"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock x:Name="ElapsedText" FontSize="11" Margin="10,2,0,0"
                               FontFamily="{StaticResource GameFont}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <Button Content="✕" Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right" Click="CloseButton_Click"/>
            </Grid>

            <!-- 플레이어 탭 선택 -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                <StackPanel x:Name="PlayerTabPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- 스킬 목록 -->
            <ListView Grid.Row="2" x:Name="SkillListView"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="스킬" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SkillName}"
                                               FontFamily="{StaticResource GameFont}"
                                               Foreground="White" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="피해량" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalDamage, StringFormat={}{0:N0}}"
                                               FontFamily="{StaticResource GameFont}"
                                               Foreground="White" FontSize="11"
                                               HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="횟수" Width="55">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HitCount}"
                                               FontFamily="{StaticResource GameFont}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="평균" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AverageDamage, StringFormat={}{0:N0}}"
                                               FontFamily="{StaticResource GameFont}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="비율" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DamageShare, StringFormat={}{0:P1}}"
                                               FontFamily="{StaticResource GameFont}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2A4A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Button Grid.Row="3" Content="닫기" Height="28" Width="80"
                    HorizontalAlignment="Right" Margin="0,8,0,0"
                    Style="{StaticResource IconButton}"
                    Foreground="White" Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
