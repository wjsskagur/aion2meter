<Application x:Class="Aion2Meter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Aion2Meter.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <converters:PercentToWidthConverter x:Key="PercentToWidth"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:LocalPlayerColorConverter x:Key="LocalPlayerColor"/>
            <converters:LocalPlayerBarColorConverter x:Key="LocalPlayerBarColor"/>
            <converters:DpsFormatter x:Key="DpsFormat"/>
            <converters:DamageFormatter x:Key="DamageFormat"/>
            <converters:PercentFormatter x:Key="PercentFormat"/>

            <Color x:Key="BackgroundColor">#1A1A2E</Color>
            <Color x:Key="PanelColor">#16213E</Color>
            <Color x:Key="AccentColor">#E94560</Color>
            <Color x:Key="TextSecondaryColor">#A0A0B0</Color>
            <Color x:Key="BorderColor">#2A2A4A</Color>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

            <FontFamily x:Key="GameFont">Malgun Gothic, Segoe UI</FontFamily>

            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2A4A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
