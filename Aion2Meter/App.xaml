<Application x:Class="Aion2Meter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Aion2Meter.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!-- 전역 Converter 등록 (모든 XAML에서 StaticResource로 사용 가능) -->
            <converters:PercentToWidthConverter x:Key="PercentToWidth"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:LocalPlayerColorConverter x:Key="LocalPlayerColor"/>
            <converters:LocalPlayerBarColorConverter x:Key="LocalPlayerBarColor"/>
            <converters:DpsFormatter x:Key="DpsFormat"/>
            <converters:DamageFormatter x:Key="DamageFormat"/>
            <converters:PercentFormatter x:Key="PercentFormat"/>

            <!-- ── 색상 팔레트 ── -->
            <Color x:Key="BackgroundColor">#1A1A2E</Color>      <!-- 딥 네이비 -->
            <Color x:Key="PanelColor">#16213E</Color>           <!-- 패널 배경 -->
            <Color x:Key="AccentColor">#E94560</Color>          <!-- 강조색 (빨강계) -->
            <Color x:Key="AccentBlueColor">#0F3460</Color>      <!-- 보조 강조 -->
            <Color x:Key="BarColor">#E94560</Color>             <!-- DPS 바 색상 -->
            <Color x:Key="LocalBarColor">#4CAF50</Color>        <!-- 본인 DPS 바 -->
            <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
            <Color x:Key="TextSecondaryColor">#A0A0B0</Color>
            <Color x:Key="BorderColor">#2A2A4A</Color>

            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="BarBrush" Color="{StaticResource BarColor}"/>
            <SolidColorBrush x:Key="LocalBarBrush" Color="{StaticResource LocalBarColor}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

            <!-- ── 전역 폰트 ── -->
            <FontFamily x:Key="GameFont">Malgun Gothic, Segoe UI</FontFamily>

            <!-- ── 버튼 기본 스타일 ── -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2A4A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
